<Window x:Class="CPUSetSetter.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:proc="clr-namespace:CPUSetSetter.UI.Tabs.Processes"
        xmlns:masks="clr-namespace:CPUSetSetter.UI.Tabs.Masks"
        xmlns:rules="clr-namespace:CPUSetSetter.UI.Tabs.Rules"
        xmlns:settings="clr-namespace:CPUSetSetter.UI.Tabs.Settings"
        mc:Ignorable="d"
        Title="CPU Set Setter"
        Height="574"
        MinHeight="574"
        Width="1020"
        MinWidth="900">

    <Grid>
        <!--Windows Game Mode Checkbox-->
        <CheckBox x:Name="GameModeCheckBox" 
                  Content="Windows Game Mode" 
                  ToolTip="When Windows Game Mode is enabled, all Masks are cleared on any running process to allow for full Core Parking on supported CPUs. Disabling restores all active Masks."
                  HorizontalAlignment="Right" 
                  VerticalAlignment="Top" 
                  Margin="0,5,5,0"
                  Panel.ZIndex="1"/>
                  
        <TabControl>
            <!--Processes Tab-->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Processes"/>
                </TabItem.Header>

                <proc:ProcessesTab/>
            </TabItem>

            <!--Masks Tab-->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Masks"/>
                </TabItem.Header>

                <masks:MasksTab/>
            </TabItem>

            <!--Rules-->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Rules"/>
                </TabItem.Header>

                <rules:RulesTab/>
            </TabItem>

            <!--Settings-->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Settings"/>
                </TabItem.Header>

                <settings:SettingsTab/>
            </TabItem>
            </TabControl>
    </Grid>
</Window>
